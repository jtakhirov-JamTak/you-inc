# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# AI APIs (server-side only). Anthropic is wired for the AI features added in Phase B.
ANTHROPIC_API_KEY=sk-ant-...

# Admin batch job secret (optional). When set, enables POST /api/admin/recompute,
# which force-replays every user's price projection under the current SCORING_VERSION
# (run it after a scoring-constant tune + version bump). Unset = the route 404s (off).
# Use a long random string. Call with: Authorization: Bearer <this value>.
# ADMIN_TASK_SECRET=replace-with-a-long-random-string

# Upstash Redis (optional — falls back to in-memory rate limiting without these)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# Observability (optional)
# SENTRY_DSN is read by server + edge runtimes.
# NEXT_PUBLIC_SENTRY_DSN is read by the browser client.
# Next only exposes NEXT_PUBLIC_* vars to the browser, so the two env
# vars are separate even though in practice they hold the same Sentry
# project DSN. Both are no-ops when unset; local dev works without them.
# SENTRY_DSN=https://xxxxx@o000000.ingest.sentry.io/0000000
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o000000.ingest.sentry.io/0000000
